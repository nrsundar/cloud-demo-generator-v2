{
  "name": "cloud-demo-generator-v3",
  "version": "1.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Cloud Demo Generator v3 - AWS Cloudscape web app with Cognito auth",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/production.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/production.js",
    "check": "tsc",
    "db:push": "drizzle-kit push"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@cloudscape-design/components": "^3.0.0",
    "@cloudscape-design/global-styles": "^1.0.0",
    "@tanstack/react-query": "^5.60.5",
    "@types/archiver": "^6.0.3",
    "amazon-cognito-identity-js": "^6.3.12",
    "archiver": "^7.0.1",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "express": "^4.21.2",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wouter": "^3.3.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.16.11",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "drizzle-kit": "^0.30.4",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.1",
    "typescript": "5.6.3",
    "vite": "^5.4.14"
  }
}
