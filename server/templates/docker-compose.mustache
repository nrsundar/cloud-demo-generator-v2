version: '3.8'

services:
  postgres:
    image: postgis/postgis:15-3.4
    container_name: {{config.repositoryName}}_db
    environment:
      POSTGRES_DB: pgrouting_db
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./sql:/docker-entrypoint-initdb.d
    networks:
      - pgrouting_network

  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: {{config.repositoryName}}_pgadmin
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@example.com
      PGADMIN_DEFAULT_PASSWORD: admin
    ports:
      - "8080:80"
    depends_on:
      - postgres
    networks:
      - pgrouting_network
    volumes:
      - pgadmin_data:/var/lib/pgadmin

{{#config.includeAPI}}
{{#config.language}}
{{#equals language "python"}}
  api:
    build:
      context: .
      dockerfile: Dockerfile.python
    container_name: {{config.repositoryName}}_api
    ports:
      - "5000:5000"
    depends_on:
      - postgres
    environment:
      DATABASE_URL: postgresql://postgres:postgres@postgres:5432/pgrouting_db
    networks:
      - pgrouting_network
{{/equals}}
{{#equals language "nodejs"}}
  api:
    build:
      context: .
      dockerfile: Dockerfile.node
    container_name: {{config.repositoryName}}_api
    ports:
      - "3000:3000"
    depends_on:
      - postgres
    environment:
      DATABASE_URL: postgresql://postgres:postgres@postgres:5432/pgrouting_db
    networks:
      - pgrouting_network
{{/equals}}
{{/config.language}}
{{/config.includeAPI}}

volumes:
  postgres_data:
  pgadmin_data:

networks:
  pgrouting_network:
    driver: bridge
